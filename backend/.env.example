# Backend environment variables — copy to .env for local dev.
# In production (Render) these are set in the dashboard / render.yaml.

# MongoDB Atlas connection string (required)
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster.mongodb.net/?appName=Cluster0

# Auth (required)
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRE=7d

# Server
PORT=5000
NODE_ENV=development

# Allowed frontend origin(s) for CORS — comma-separated for multiple
FRONTEND_URL=http://localhost:5173

# --- Optional: Google OAuth (login with Google) ---
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_REDIRECT_URI=

# --- Optional: Email notifications ---
# EMAIL_HOST=
# EMAIL_PORT=
# EMAIL_USER=
# EMAIL_PASSWORD=
# EMAIL_FROM=

# --- Optional: cron schedule for escalation checks ---
# ESCALATION_CHECK_INTERVAL=*/5 * * * *
